{
  "expo": {
    "name": "Telealpha Acerto",
    "slug": "telealpha-acerto",
    "scheme": "telealpha-acerto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Usamos a câmera para fotografar comprovantes de despesa."
      }
    },
    "android": {
      "package": "com.telealpha.acerto",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Usamos a câmera para fotografar comprovantes de despesa."
        }
      ],
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "272e924e-58dc-4912-8928-4707caea4662"
      }
    },
    "owner": "leorf88"
  }
}
